// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider            = "prisma-client"
  output              = "../src/generated/prisma"
  previewFeatures     = ["partialIndexes"]
  importFileExtension = "ts"
}

datasource db {
  provider = "postgresql"
}

enum CampaignRole {
  GM
  PLAYER
}

enum CharacterType {
  PC
  NPC
}

enum MembershipStatus {
  ACTIVE
  RETIRED
}

enum NoteVisibility {
  PRIVATE
  SHARED
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  displayName  String
  createdAt    DateTime @default(now())

  campaignsCreated Campaign[]           @relation("CampaignCreator")
  memberships      CampaignMembership[]
  characters       Character[]
  notes            Note[]
}

model Campaign {
  id          String   @id @default(uuid())
  name        String
  description String?
  createdById String
  createdAt   DateTime @default(now())

  createdBy   User                 @relation("CampaignCreator", fields: [createdById], references: [id])
  memberships CampaignMembership[]
  characters  CampaignCharacter[]
  encounters  Encounter[]          // NEW
}

model CampaignMembership {
  id         String       @id @default(uuid())
  campaignId String
  userId     String
  role       CampaignRole
  joinedAt   DateTime     @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id])
  user     User     @relation(fields: [userId], references: [id])

  @@unique([campaignId, userId])
}

model Character {
  id            String        @id @default(uuid())
  ownerId       String
  name          String
  class         String
  race          String
  level         Int           @default(1)
  background    String?
  characterType CharacterType @default(PC)

  strength     Int @default(10)
  dexterity    Int @default(10)
  constitution Int @default(10)
  intelligence Int @default(10)
  wisdom       Int @default(10)
  charisma     Int @default(10)

  maxHp       Int @default(8)
  currentHp   Int @default(8)
  temporaryHp Int @default(0)
  armorClass  Int @default(10)
  speed       Int @default(30)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner     User                @relation(fields: [ownerId], references: [id])
  inventory InventoryItem[]
  campaigns CampaignCharacter[]
}

model CampaignCharacter {
  id          String           @id @default(uuid())
  campaignId  String
  characterId String
  status      MembershipStatus @default(ACTIVE)
  joinedAt    DateTime         @default(now())

  campaign  Campaign  @relation(fields: [campaignId], references: [id])
  character Character @relation(fields: [characterId], references: [id])

  @@unique([campaignId, characterId])  // NEW — prevents duplicate adds
  @@unique([characterId], where: raw("status = 'ACTIVE'"))
}

model InventoryItem {
  id          String  @id @default(uuid())
  characterId String
  name        String
  quantity    Int     @default(1)
  weight      Float?
  description String?
  sourceIndex String?

  character Character @relation(fields: [characterId], references: [id])
}

model Note {
  id         String         @id @default(uuid())
  authorId   String
  title      String
  body       String
  visibility NoteVisibility @default(PRIVATE)
  createdAt  DateTime       @default(now())

  author User @relation(fields: [authorId], references: [id])
}

model Encounter {
  id         String   @id @default(uuid())
  campaignId String
  name       String
  notes      String?
  createdAt  DateTime @default(now())

  campaign Campaign          @relation(fields: [campaignId], references: [id])
  monsters EncounterMonster[]
}

model EncounterMonster {
  id           String  @id @default(uuid())
  encounterId  String
  monsterIndex String
  customName   String?
  maxHp        Int
  currentHp    Int
  notes        String?
  initiative   Int?

  encounter Encounter @relation(fields: [encounterId], references: [id])
}