generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String     @id @default(cuid())
  email       String     @unique
  campaigns   Campaign[]
  createdAt   DateTime   @default(now())
}

model Campaign {
  id           String    @id @default(cuid())
  title        String
  description  String?
  createdAt    DateTime  @default(now())

  userId       String
  user         User @relation(fields: [userId], references: [id])
}